# ─── Required ─────────────────────────────────────────────────────────────────

# URL of the running Stexio proxy (apps/proxy)
NEXT_PUBLIC_PROXY_URL=http://localhost:3006

# URL of this test client — used by proxy to reach echo-mcp during tests
NEXT_PUBLIC_TEST_CLIENT_URL=http://localhost:3001

# Funded Stellar TESTNET keypair used by payment tests (server-side only, never exposed to browser)
# Fund with: https://friendbot.stellar.org?addr=<PUBLIC_KEY>
# Add USDC trustline, then get testnet USDC from: https://laboratory.stellar.org
TEST_STELLAR_SECRET_KEY=S...

# Stellar G... address that receives test payments (must have USDC trustline on testnet)
TEST_RECIPIENT_ADDRESS=G...

# ─── Auth tests ────────────────────────────────────────────────────────────────

# Credentials used to sign up / sign in during auth tests
TEST_AUTH_EMAIL=test@stexio.dev
TEST_AUTH_PASSWORD=TestPassword123!

# ─── x402-Session test (optional) ─────────────────────────────────────────────

# Public key of the proxy's STELLAR_SERVER_SECRET_KEY
# Run: node -e "const {Keypair}=require('@stellar/stellar-sdk'); console.log(Keypair.fromSecret('PROXY_SECRET').publicKey())"
TEST_SERVER_STELLAR_ADDRESS=G...

# Session contract ID from the proxy's SESSION_CONTRACT_ID env
# Can be any valid C... address format — does not need to be deployed for signature verification
TEST_SESSION_CONTRACT_ID=C...

# ─── MPP Session test (optional) ──────────────────────────────────────────────

# Deployed one-way-channel Soroban contract address (C...)
# Also requires MPP_CHANNEL_ADDRESS + COMMITMENT_PUBKEY on the proxy
# See resources/mpp_session_guide.md for deployment instructions
TEST_MPP_CHANNEL_ADDRESS=C...

# Ed25519 commitment key for MPP Session — 64-char hex raw seed
# Must match the COMMITMENT_PUBKEY (G...) set on the proxy
TEST_COMMITMENT_SECRET=

# ─── x402 Stellar facilitator test (optional) ─────────────────────────────────

# Facilitator URL used by the direct x402-stellar facilitator test
# Defaults to https://x402.org/facilitator if not set
FACILITATOR_URL=https://x402.org/facilitator

# ─── Notes ────────────────────────────────────────────────────────────────────
# - x402-Coinbase facilitator: needs TEST_STELLAR_SECRET_KEY + TEST_RECIPIENT_ADDRESS funded with USDC
# - x402-Stellar facilitator: same as above — calls facilitator verify/settle directly
# - x402-turbo-stellar: requires TEST_SERVER_STELLAR_ADDRESS + TEST_SESSION_CONTRACT_ID
# - MPP Charge: requires TEST_RECIPIENT_ADDRESS
# - MPP Session: requires TEST_RECIPIENT_ADDRESS (TEST_MPP_CHANNEL_ADDRESS optional, has default)
# - API Key Mode: requires TEST_AUTH_EMAIL + TEST_AUTH_PASSWORD

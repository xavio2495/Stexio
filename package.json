{
  "name": "stexio",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel --filter='./apps/*' --filter='./packages/*'",
    "dev:proxy": "turbo run dev --filter=proxy",
    "dev:app": "turbo run dev --filter=app",
    "dev:all": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "e2e": "turbo run e2e"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "turbo": "^2.1.3",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "overrides": {
      "@modelcontextprotocol/sdk": "1.18.2"
    }
  },
  "dependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.1"
  }
}
